{
    "name": "@cervid/vision",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "keywords": [
        "computer-vision",
        "image-processing",
        "jpeg-decoder",
        "jpeg-progressive",
        "image-decoding",
        "image-encoding",
        "nodejs",
        "typescript",
        "performance",
        "high-performance",
        "multithreading",
        "worker-threads",
        "sharedarraybuffer",
        "zero-dependencies",
        "low-level",
        "opencv-alternative",
        "pure-nodejs",
        "image-kernels",
        "grayscale",
        "blur",
        "edge-detection",
        "sobel",
        "idct",
        "dct",
        "jpeg",
        "ppm"
    ],
    "author": {
        "name": "Aldair Beltran",
        "email": "support@cervid.io"
    },
    "license": "MIT",
    "engines": {
        "node": ">=20.0.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.4"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "coverage": "c8 node --import tsx --test src/**/*.spec.ts",
        "prepare": "husky",
        "prepublishOnly": "npm run lint && npm run test && npm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "audit": "npm audit"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix",
            "prettier --write",
            "eslint --max-warnings 0 --no-warn-ignored"
        ]
    }
}